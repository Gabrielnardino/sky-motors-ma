# App
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# WAHA
WAHA_URL=https://seu-waha.up.railway.app
WAHA_API_KEY=sua_api_key
WAHA_SESSION=default

# Redis — use REDIS_URL interno do Railway em produção
# Para dev local: pegue REDIS_PUBLIC_URL no painel Railway > Redis > Variables
REDIS_URL=redis://default:SUA_SENHA@host:port

# PostgreSQL — use DATABASE_URL interno do Railway em produção
# Para dev local: pegue DATABASE_PUBLIC_URL no painel Railway > Postgres > Variables
DATABASE_URL=postgresql://postgres:SUA_SENHA@host:port/railway

# Anthropic (Claude Haiku)
# console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Groq (Whisper — transcrição de áudio, gratuito)
# console.groq.com
GROQ_API_KEY=gsk_...

# LangSmith (observabilidade — smith.langchain.com)
LANG_SMITH_API_KEY=lsv2_...

# Sky Motors
VENDOR_PHONE=1XXXXXXXXXX
DEALER_NAME=Sky Motors
DEALER_LOCATION=Chelmsford, MA
DEALER_TIMEZONE=America/New_York
