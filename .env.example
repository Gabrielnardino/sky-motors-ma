# App
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# WAHA (já online no Railway)
WAHA_URL=https://waha-production-8d99.up.railway.app
WAHA_API_KEY=skymotor2025
WAHA_SESSION=default

# Redis — para desenvolvimento local, use a URL pública (TCP proxy)
# Pegue o valor resolvido de REDIS_PUBLIC_URL no painel do Railway (Redis > Variables)
# Formato: redis://default:rHyzBnWHnJFzDvcGicrGqkMKemsOyIGD@<tcp-proxy-host>:<tcp-proxy-port>
REDIS_URL=redis://default:rHyzBnWHnJFzDvcGicrGqkMKemsOyIGD@<PREENCHER_TCP_HOST>:<PREENCHER_TCP_PORT>

# PostgreSQL — para desenvolvimento local, use a URL pública (TCP proxy)
# Pegue o valor resolvido de DATABASE_PUBLIC_URL no painel do Railway (Postgres > Variables)
# Formato: postgresql://postgres:YgchHWDjdKTwjLfHniiDAZZWlxnoysIf@<tcp-proxy-host>:<tcp-proxy-port>/railway
DATABASE_URL=postgresql://postgres:YgchHWDjdKTwjLfHniiDAZZWlxnoysIf@<PREENCHER_TCP_HOST>:<PREENCHER_TCP_PORT>/railway

# Anthropic (Claude Haiku — interpretação de linguagem natural + inventário)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (Whisper — transcrição de áudios do WhatsApp, gratuito)
# Crie sua chave em: console.groq.com
GROQ_API_KEY=gsk_...

# Sky Motors
VENDOR_PHONE=1XXXXXXXXXX
DEALER_NAME=Sky Motors
DEALER_LOCATION=Chelmsford, MA
DEALER_TIMEZONE=America/New_York
